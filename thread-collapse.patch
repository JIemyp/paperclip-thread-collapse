+function stripMarkdown(text: string): string {
+  return text
+    .replace(/```[\s\S]*?```/g, "[code]")
+    .replace(/`[^`]+`/g, (m) => m.slice(1, -1))
+    .replace(/!\[.*?\]\(.*?\)/g, "[image]")
+    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
+    .replace(/^#+\s+/gm, "")
+    .replace(/\*\*(.+?)\*\*/g, "$1")
+    .replace(/\*(.+?)\*/g, "$1")
+    .replace(/_{1,2}(.+?)_{1,2}/g, "$1")
+    .replace(/~~(.+?)~~/g, "$1")
+    .replace(/^[-*>]\s+/gm, "")
+    .replace(/\n+/g, " ")
+    .trim();
+}
